SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://your-db-host:3306/roomrent_maharashtra?useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password

# JWT
APP_JWT_SECRET=change-this-to-a-long-random-secret-please-use-64-plus-chars
APP_JWT_EXPIRATION_MS=86400000

# Mail
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@your-domain.com
SPRING_MAIL_PASSWORD=your_mail_password_or_app_password
APP_MAIL_FROM=your_email@your-domain.com

# Frontend
APP_FRONTEND_BASE_URL=https://your-domain.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://your-domain.com,https://www.your-domain.com

# Admin bootstrap
APP_ADMIN_EMAIL=admin@roomrentmaharashtra.com
APP_ADMIN_PASSWORD=Admin@12345
APP_ADMIN_NAME=RoomRent Maharashtra Admin
APP_ADMIN_PHONE=9876543210
